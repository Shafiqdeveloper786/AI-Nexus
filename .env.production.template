# ═══════════════════════════════════════════════════════════════════════════════
#  AI Nexus v4.0.2 — Production Environment Variables
#  Copy this file to .env.production (or paste into your hosting provider's
#  environment dashboard — Vercel / Railway / Render / Fly.io).
#  NEVER commit the real .env.production file to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core Next.js ───────────────────────────────────────────────────────────────
# Your production domain — no trailing slash
NEXTAUTH_URL=https://your-domain.com

# Generate with: openssl rand -base64 32
# Or online:     https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

NODE_ENV=production


# ─── Google OAuth 2.0 ───────────────────────────────────────────────────────────
# Setup steps:
#   1. Go to https://console.cloud.google.com/
#   2. Select your project → APIs & Services → Credentials
#   3. Create OAuth 2.0 Client ID (type: Web application)
#   4. Authorized JavaScript origins:
#        https://your-domain.com
#   5. Authorized redirect URIs (EXACT match required):
#        https://your-domain.com/api/auth/callback/google
#   6. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET


# ─── Databases ──────────────────────────────────────────────────────────────────
# Prisma (PostgreSQL or MongoDB via Prisma)
# MongoDB Atlas → Connect → Drivers → copy the connection string
# Replace <password> with your actual Atlas password
DATABASE_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai_nexus_auth?retryWrites=true&w=majority

# Mongoose (separate Atlas connection for AI data)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/ai_nexus?retryWrites=true&w=majority


# ─── AI Services ────────────────────────────────────────────────────────────────
# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_WITH_GROQ_API_KEY

# HuggingFace — https://huggingface.co/settings/tokens (type: Read)
HF_TOKEN=hf_REPLACE_WITH_HF_TOKEN


# ─── Email (Nodemailer / Gmail) ─────────────────────────────────────────────────
# Gmail App Password — NOT your normal Gmail password
# Setup: Google Account → Security → 2-Step Verification → App passwords → Generate
NODEMAILER_EMAIL=your-email@gmail.com
NODEMAILER_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD


# ═══════════════════════════════════════════════════════════════════════════════
#  GOOGLE CLOUD CONSOLE QUICK REFERENCE
# ═══════════════════════════════════════════════════════════════════════════════
#
#  Direct link to create credentials:
#    https://console.cloud.google.com/apis/credentials
#
#  Required OAuth Scopes (already handled by NextAuth — no manual setup):
#    • openid
#    • email
#    • profile
#
#  OAuth Consent Screen (must be configured before credentials work):
#    https://console.cloud.google.com/apis/credentials/consent
#    → App name: "AI Nexus"
#    → User support email: your-email@gmail.com
#    → Authorized domains: your-domain.com
#    → Developer contact: your-email@gmail.com
#
#  If using Vercel, set NEXTAUTH_URL to your Vercel project URL:
#    https://your-project.vercel.app
#  And add this to Authorized redirect URIs in Google Console:
#    https://your-project.vercel.app/api/auth/callback/google
#
# ═══════════════════════════════════════════════════════════════════════════════
